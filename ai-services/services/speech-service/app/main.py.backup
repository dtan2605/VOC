    return os.getenv("SPEECH_DB_HOST", "localhost")


def db_port() -> int:
    return int(os.getenv("SPEECH_DB_PORT", "3306"))


def db_name() -> str:
    return os.getenv("SPEECH_DB_NAME", "voc_speaking")


def db_user() -> str:
    return os.getenv("SPEECH_DB_USER", "voc_user")


